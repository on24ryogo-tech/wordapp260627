# TestFlight 自動配信レーン
# 必要な環境変数（GitHub Secrets から注入）:
#   ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_P8_BASE64  … App Store Connect APIキー
#   MATCH_PASSWORD                                   … 証明書リポジトリの暗号化パスフレーズ
#   MATCH_GIT_BASIC_AUTH                             … "user:PAT" のBase64（certsリポジトリ用）

default_platform(:ios)

platform :ios do
  desc "Build signed IPA and upload to TestFlight"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8_BASE64"],
      is_key_content_base64: true
    )

    match(
      type: "appstore",
      app_identifier: "com.manabiph.lexiconlab",
      git_url: "https://github.com/on24ryogo-tech/lexiconlab-certs.git",
      api_key: api_key,
      readonly: false
    )

    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: ENV["GITHUB_RUN_NUMBER"] || "1"
    )

    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      output_directory: "output"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "output/App.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
